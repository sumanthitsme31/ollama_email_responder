
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-email@gmail.com
IMAP_PASSWORD=your-app-password-or-password

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-or-password
SMTP_FROM_EMAIL=your-email@gmail.com
SMTP_FROM_NAME="AI Auto Responder"

# n8n Configuration
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# N8N_ENCRYPTION_KEY=some-super-secret-key-here   # Optional: for extra security


# Optional: Docker Settings
COMPOSE_PROJECT_NAME=ai-email-responder

# Ollama (Optional - rarely needed)
# OLLAMA_HOST=ollama
# OLLAMA_PORT=11434